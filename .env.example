# LLM INTELLIGENCE
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
ZOM_MAX_RETRIES=3
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_HOST=http://localhost:11434

# FINANCIAL (ZEZE-FIN)
BINANCE_API_KEY=
BINANCE_SECRET=

# MEDIA & AUTOMATION (ZEZE-MEDIA)
YOUTUBE_API_KEY=
GMAIL_CREDENTIALS_PATH=

# DATABASE & CACHE
REDIS_PASSWORD=your_redis_password
CHROMA_HOST=zezelabs_chroma

# DOCKER INFRA
OPENJARVIS_PATH=.
WORKSPACE_DIR=./workspace

# DEEPSEEK RUNTIME & SECURITY POLICY
AI_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
ZOM_ENABLE_LEGACY_OPENCLAW_CLEANUP=false
ZOM_ENABLE_HERMES_GATEWAY=false
ZOM_ENABLE_AUTO_GITHUB_PUSH=false
ZOM_ENABLE_VOICE_LISTENER=false
ZOM_MOCK_DEEPSEEK=false
