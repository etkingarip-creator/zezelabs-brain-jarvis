# ─────────────────────────────────────────────────────
# ZEZELABS BRAIN JARVIS - MASTER ENVIRONMENT TEMPLATE
# ─────────────────────────────────────────────────────

# LLM INTELLIGENCE
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
ZOM_MAX_RETRIES=3
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_HOST=http://localhost:11434

# FINANCIAL (ZEZE-FIN)
BINANCE_API_KEY=
BINANCE_SECRET=

# MEDIA & AUTOMATION (ZEZE-MEDIA)
YOUTUBE_API_KEY=
GMAIL_CREDENTIALS_PATH=

# DATABASE & CACHE
REDIS_PASSWORD=your_redis_password
CHROMA_HOST=zezelabs_chroma

# DOCKER INFRA
OPENJARVIS_PATH=.
WORKSPACE_DIR=./workspace

# DEEPSEEK RUNTIME & SECURITY POLICY
AI_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here
ZOM_ENABLE_LEGACY_OPENCLAW_CLEANUP=false
ZOM_ENABLE_HERMES_GATEWAY=false
ZOM_ENABLE_AUTO_GITHUB_PUSH=false
ZOM_ENABLE_VOICE_LISTENER=false
ZOM_MOCK_DEEPSEEK=true

# --- Phase: Desktop & Hybrid Orchestration ---
ZOM_AI_MODE=hybrid_deepseek_hermes
ZOM_ENABLE_HERMES_SYNC=false
ZOM_ENABLE_OLLAMA_FALLBACK=false
ZOM_ENABLE_DESKTOP_AUTO_BACKEND=true
ZOM_DESKTOP_BACKEND_HOST=127.0.0.1
ZOM_DESKTOP_BACKEND_PORT=8000
ZOM_ENABLE_CLAWDE_OPERATOR=true
